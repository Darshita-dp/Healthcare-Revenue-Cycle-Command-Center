# =============================================================================
# Backend environment — example values only. Copy to `.env` for local use;
# `.env` is gitignored. Do NOT put secrets in this example file.
# =============================================================================

# FRONTEND_URL — origin(s) allowed by the FastAPI CORS middleware.
#
# * Used by api/main.py to build the CORS allowlist. The default localhost
#   dev origins (http://localhost:5173 and http://127.0.0.1:5173) are
#   always present; FRONTEND_URL is *added* to that list.
# * The backend supports a comma-separated list of origins here — every
#   entry is normalized (trailing slash stripped) before being added.
# * The production value MUST exactly match the deployed frontend origin.
# * No trailing slash is preferred (a trailing slash is stripped anyway).
# * Wildcards (`*`) are intentionally not supported for security.
FRONTEND_URL=http://localhost:5173

# Optional: PostgreSQL connection string. Leave UNSET for CSV mode (the
# default). CSV mode requires no database and is what Render deploys use.
# Only fill this in if you are running the local docker-compose stack;
# choose your own credentials — the placeholder below is not real.
# DATABASE_URL=postgresql+psycopg2://<USER>:<PASSWORD>@localhost:5432/revenue_cycle
