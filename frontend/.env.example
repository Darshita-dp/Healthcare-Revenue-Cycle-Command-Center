# =============================================================================
# Frontend environment — example values only. Copy to `frontend/.env` for
# local use; `.env` is gitignored. Do NOT put secrets in this example file.
# (Vite exposes any VITE_* variable to browser code — never put a secret
# in one of these, even in production.)
# =============================================================================

# VITE_API_URL — absolute origin of the FastAPI backend.
#
# * Embedded into the JavaScript bundle at BUILD TIME by Vite. Changing
#   the value requires a fresh `npm run build` / redeploy.
# * Local development normally leaves this UNSET — the Vite dev server
#   proxies /api and /health to http://localhost:8000 (see vite.config.ts),
#   so same-origin relative paths work without any env var.
# * On Render, set this to the deployed backend's origin, e.g.
#     https://healthcare-rcm-api.onrender.com
#   No trailing slash — the client trims one anyway.
VITE_API_URL=http://localhost:8000
